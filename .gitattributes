# Disable auto line ending conversion
* text=auto 


# Unity text files - use LF
*.cs text eol=lf
*.js text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.glsl text eol=lf
*.asmdef text eol=lf
*.meta text eol=lf
*.prefab text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.unity text eol=lf
*.asset text eol=lf
*.prefs text eol=lf
*.dwlt text eol=lf

# Unity Assets - binary (LFS)
*.psd filter=lfs diff=lfs merge=lfs -text
